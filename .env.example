ANTHROPIC_API_KEY=sk-ant-...
CHATBOT_MODEL=claude-sonnet-4-6
CHATBOT_CSV_PATH=/opt/chatbot/data/transactions.csv
CHATBOT_PORT=8083
TURNSTILE_SECRET=

# Hybrid model router (Phase 3). FORCE_MODEL overrides the classifier —
# leave unset in production so the router picks the right tier per query.
# Allowed values: haiku | sonnet | opus
# FORCE_MODEL=

# Per-tier model IDs. Uncomment to override the defaults baked into
# model_router.py. If unset, the router uses the defaults below.
# CHATBOT_MODEL_HAIKU=claude-haiku-4-5-20251001
# CHATBOT_MODEL_SONNET=claude-sonnet-4-6
# CHATBOT_MODEL_OPUS=claude-opus-4-7
